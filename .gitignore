# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
pip-wheel-metadata/
*.pyc

# ── Virtual environments ───────────────────────────────────────────────────────
.env
.venv
venv/
env/
ENV/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Model weights (large, downloaded on demand) ────────────────────────────────
*.bin
*.safetensors
*.gguf
*.ggml
*.pt
*.pth
*.ckpt

# ── HuggingFace cache ──────────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/

# ── Compiled output (regenerated by scripts) ───────────────────────────────────
# Binary phase configs (large, binary)
output/*.phcfg
output/real/
# Full phase map JSON for real model (38MB+, too large for git)
output/phase_map.json

# GDS chip masks (large binary; keep demo SVG layouts instead)
output/gds/*.gds

# Large numpy arrays from simulations (regeneratable)
output/simulations/*.npy

# Netlist (125K lines, regeneratable)
output/netlists/*.pntl

# Test runner output (plain text, regeneratable)
output/tests/test_results.txt

# ── Keep these output files (small, illustrative for repo readers) ─────────────
# output/phase_map_demo.json         → too large (38MB), excluded below
# output/layout/*.svg                → kept (small, visually useful)
# output/gds/*.lyp                   → kept (tiny KLayout color scheme)
# output/gds/gds_manifest.json       → kept
# output/netlists/manifest_demo.json → kept
# output/simulations/*.json          → kept (error statistics)
# output/simulations/*.svg           → kept (comparison plots)
# output/README.md                   → kept

output/phase_map_demo.json

